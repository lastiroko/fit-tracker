{
  "rewrites": [
    { "source": "/api/:path*", "destination": "https://fit-tracker-api.fly.dev/api/:path*" },
    { "source": "/oauth2/:path*", "destination": "https://fit-tracker-api.fly.dev/oauth2/:path*" },
    { "source": "/login/:path*", "destination": "https://fit-tracker-api.fly.dev/login/:path*" },
    { "source": "/logout", "destination": "https://fit-tracker-api.fly.dev/logout" },
    { "source": "/actuator/:path*", "destination": "https://fit-tracker-api.fly.dev/actuator/:path*" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
